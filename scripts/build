#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# check if release flag is passed
if [[ "${1:-}" == "release" ]]; then
    BUILD_TYPE="Release"
    BUILD_DIR="${BUILD_DIR:-"$ROOT_DIR/build_release"}"
else
    BUILD_TYPE="Debug"
    BUILD_DIR="${BUILD_DIR:-"$ROOT_DIR/build"}"
fi

GENERATOR="${CMAKE_GENERATOR:-Unix Makefiles}"

echo "Configuring CMake project (build type: ${BUILD_TYPE}, generator: ${GENERATOR})..."
cmake -S "$ROOT_DIR" -B "$BUILD_DIR" -G "$GENERATOR" -DCMAKE_BUILD_TYPE="${BUILD_TYPE}"

echo "Building DearSQL application..."
cmake --build "$BUILD_DIR" --target dear-sql

if [[ "$(uname)" == "Darwin" ]]; then
    echo "Build complete. Binary located at: $BUILD_DIR/DearSQL.app"
else
    echo "Build complete. Binary located at: $BUILD_DIR/dear-sql"
fi
