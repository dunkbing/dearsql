#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Load app metadata
source "$ROOT_DIR/APP_METADATA"

# Check for vcpkg
if [[ -z "${VCPKG_ROOT:-}" ]]; then
    if [[ -d "$HOME/vcpkg" ]]; then
        export VCPKG_ROOT="$HOME/vcpkg"
    else
        echo "Error: vcpkg not found. Install it with:"
        echo "  git clone https://github.com/microsoft/vcpkg.git ~/vcpkg"
        echo "  ~/vcpkg/bootstrap-vcpkg.sh"
        exit 1
    fi
fi
echo "Using vcpkg at: $VCPKG_ROOT"

# Parse arguments
BUILD_TYPE="Debug"
BUILD_DIR="$ROOT_DIR/build"
RECONFIGURE=false
for arg in "$@"; do
    case "$arg" in
        release) BUILD_TYPE="Release"; BUILD_DIR="$ROOT_DIR/build_release" ;;
        --reconfigure) RECONFIGURE=true ;;
    esac
done
BUILD_DIR="${BUILD_DIR_OVERRIDE:-$BUILD_DIR}"
GENERATOR="${CMAKE_GENERATOR:-Unix Makefiles}"

# Only run cmake configure if build dir doesn't exist or CMakeCache is missing
if [[ ! -f "$BUILD_DIR/CMakeCache.txt" ]] || [[ "$RECONFIGURE" == true ]]; then
    echo "Configuring CMake (${BUILD_TYPE}, ${GENERATOR})..."
    cmake -S "$ROOT_DIR" -B "$BUILD_DIR" -G "$GENERATOR" -DCMAKE_BUILD_TYPE="$BUILD_TYPE"
else
    echo "Skipping CMake configure (already configured). Use --reconfigure to force."
fi

echo "Building DearSQL..."
cmake --build "$BUILD_DIR" --target dear-sql

if [[ "$(uname)" == "Darwin" ]]; then
    echo "Build complete: $BUILD_DIR/DearSQL.app"
    exit 0
fi

echo "Build complete: $BUILD_DIR/dear-sql"

# On Linux release builds, also produce .deb
if [[ "$BUILD_TYPE" != "Release" ]]; then
    exit 0
fi

if ! command -v dpkg-deb &>/dev/null; then
    echo "dpkg-deb not found, skipping .deb packaging"
    exit 0
fi

VERSION="$APP_VERSION"
ARCH="$(dpkg --print-architecture)"
PKG_NAME="$(echo "$APP_NAME" | tr '[:upper:]' '[:lower:]')"
DEB_NAME="${PKG_NAME}_${VERSION}_${ARCH}"
DEB_DIR="$BUILD_DIR/$DEB_NAME"
DEB_FILE="$BUILD_DIR/${DEB_NAME}.deb"

echo "Packaging ${DEB_NAME}.deb..."

rm -rf "$DEB_DIR"
mkdir -p "$DEB_DIR"/{DEBIAN,usr/bin,usr/share/applications}
mkdir -p "$DEB_DIR/usr/share/icons/hicolor/256x256/apps"

install -m755 "$BUILD_DIR/dear-sql" "$DEB_DIR/usr/bin/$PKG_NAME"
install -m644 "$ROOT_DIR/packaging/flatpak/$APP_IDENTIFIER.desktop" \
    "$DEB_DIR/usr/share/applications/$APP_IDENTIFIER.desktop"
install -m644 "$ROOT_DIR/assets/appicon.png" \
    "$DEB_DIR/usr/share/icons/hicolor/256x256/apps/$APP_IDENTIFIER.png"

cat > "$DEB_DIR/DEBIAN/control" <<EOF
Package: ${PKG_NAME}
Version: ${VERSION}
Section: database
Priority: optional
Architecture: ${ARCH}
Depends: libgtk-4-1, libssl3
Maintainer: Bing Bui <bing@db99.dev>
Homepage: https://dearsql.dev
Description: SQL Database Client
 DearSQL is a desktop SQL client for connecting to SQLite,
 PostgreSQL, MySQL, Redis, and MongoDB databases.
 .
 Features include syntax highlighting, query history,
 ER diagrams, and table editing.
EOF

dpkg-deb --build --root-owner-group "$DEB_DIR" "$DEB_FILE"
sha256sum "$DEB_FILE" > "${DEB_FILE}.sha256"

echo "Package created: $DEB_FILE"
