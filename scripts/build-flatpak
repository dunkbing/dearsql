#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BUILD_DIR="${BUILD_DIR:-$PROJECT_DIR/build_flatpak}"

source "$PROJECT_DIR/APP_METADATA"

echo "=== Building Flatpak ==="

# Add Flathub remote if not present
if ! flatpak remote-list | grep -q flathub; then
    echo "Adding Flathub remote..."
    flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

# Install Flatpak SDK if needed
if ! flatpak info org.gnome.Sdk//46 &>/dev/null; then
    echo "Installing GNOME SDK 46..."
    flatpak install -y flathub org.gnome.Sdk//46 org.gnome.Platform//46
fi

# Build and export to repo
cd "$PROJECT_DIR/packaging/flatpak"
flatpak-builder --repo="$BUILD_DIR/repo" --force-clean "$BUILD_DIR/build" dearsql.db99.dev.yml

# Create distributable bundle
flatpak build-bundle "$BUILD_DIR/repo" "$BUILD_DIR/DearSQL.flatpak" dearsql.db99.dev

echo "=== Flatpak created: $BUILD_DIR/DearSQL.flatpak ==="
echo ""
echo "To install locally:"
echo "  flatpak install $BUILD_DIR/DearSQL.flatpak"
echo ""
echo "To run:"
echo "  flatpak run dearsql.db99.dev"
