#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
VERSION="${VERSION:-0.1.0}"
PPA="${PPA:-ppa:dunkbing/dearsql}"
DISTRO="${DISTRO:-noble}"  # Ubuntu 24.04

echo "=== Building PPA Source Package ==="

# Check dependencies
for cmd in debuild dput; do
    if ! command -v "$cmd" &>/dev/null; then
        echo "Missing: $cmd"
        echo "Install with: sudo apt install devscripts dput"
        exit 1
    fi
done

cd "$PROJECT_DIR"

# Prepare sources (submodules + sqlite3) - Launchpad has no network access
echo "Preparing sources..."
./scripts/setup --skip-deps

# Update changelog for target distro
sed -i "1s/)[^)]*;/) ${DISTRO};/" debian/changelog

# Create orig tarball with all dependencies bundled
# (can't use git archive - it excludes submodules and untracked files)
TARBALL="../dearsql_${VERSION}.orig.tar.gz"
echo "Creating orig tarball..."
tar --exclude='.git' \
    --exclude='build' \
    --exclude='build_*' \
    --exclude='.flatpak-builder' \
    --exclude='*.flatpak' \
    -czf "$TARBALL" \
    --transform "s,^./,dearsql-${VERSION}/," \
    .

# Build source package (signed)
debuild -S -sa

# Upload to PPA
echo ""
echo "Source package built. Upload with:"
echo "  dput $PPA ../dearsql_${VERSION}-1_source.changes"
echo ""
echo "Or run: dput $PPA ../dearsql_${VERSION}-1_source.changes"
