#!/usr/bin/env bash
set -euo pipefail

# Configuration
APP_NAME="dearsql"
APP_DISPLAY_NAME="Dear SQL"
VERSION="${VERSION:-1.0.0}"
ARCH="${ARCH:-amd64}"
MAINTAINER="${MAINTAINER:-dunkbing <bing@db99.dev>}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
BUILD_DIR="${PROJECT_DIR}/build"
DEB_DIR="${BUILD_DIR}/deb-package"
OUTPUT_FILE="${BUILD_DIR}/${APP_NAME}_${VERSION}_${ARCH}.deb"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Check dependencies
check_deps() {
    local missing=()
    for cmd in dpkg-deb convert; do
        if ! command -v "$cmd" &>/dev/null; then
            missing+=("$cmd")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        log_error "Missing dependencies: ${missing[*]}"
        echo "Install with: sudo apt install dpkg imagemagick"
        exit 1
    fi
}

# Check if executable exists
check_executable() {
    if [[ ! -f "${BUILD_DIR}/dear-sql" ]]; then
        log_error "Executable not found at ${BUILD_DIR}/dear-sql"
        echo "Run ./scripts/build first"
        exit 1
    fi
}

# Create directory structure
create_structure() {
    log_info "Creating package structure..."
    rm -rf "$DEB_DIR"
    mkdir -p "$DEB_DIR"/{DEBIAN,usr/bin,usr/share/applications}
    mkdir -p "$DEB_DIR"/usr/share/icons/hicolor/{48x48,128x128,256x256,512x512}/apps
}

# Create control file
create_control() {
    log_info "Creating control file..."
    cat > "$DEB_DIR/DEBIAN/control" << EOF
Package: ${APP_NAME}
Version: ${VERSION}
Section: database
Priority: optional
Architecture: ${ARCH}
Depends: libpq5, libmariadb3 | libmysqlclient21, libsqlite3-0, libgl1, libx11-6
Maintainer: ${MAINTAINER}
Description: Desktop SQL client
 A modern GUI SQL client for SQLite, PostgreSQL, MySQL, and Redis databases.
 Features syntax highlighting, query history, ER diagrams, and table editing.
EOF
}

# Create desktop entry
create_desktop_entry() {
    log_info "Creating desktop entry..."
    cat > "$DEB_DIR/usr/share/applications/${APP_NAME}.desktop" << EOF
[Desktop Entry]
Name=${APP_DISPLAY_NAME}
Comment=Desktop SQL Client for SQLite, PostgreSQL, MySQL, and Redis
Exec=${APP_NAME}
Icon=${APP_NAME}
Terminal=false
Type=Application
Categories=Development;Database;
Keywords=sql;database;postgresql;mysql;sqlite;redis;query;
StartupWMClass=DearSQL
EOF
}

# Generate icons
create_icons() {
    log_info "Generating icons..."
    local icon_src="${PROJECT_DIR}/assets/appicon.png"

    if [[ ! -f "$icon_src" ]]; then
        log_warn "Icon not found at $icon_src, skipping icon generation"
        return
    fi

    for size in 48 128 256 512; do
        convert "$icon_src" -resize ${size}x${size} \
            "$DEB_DIR/usr/share/icons/hicolor/${size}x${size}/apps/${APP_NAME}.png"
    done
    log_info "Icons generated: 48x48, 128x128, 256x256, 512x512"
}

# Copy executable
copy_executable() {
    log_info "Copying executable..."
    cp "${BUILD_DIR}/dear-sql" "$DEB_DIR/usr/bin/${APP_NAME}"
    chmod 755 "$DEB_DIR/usr/bin/${APP_NAME}"
}

# Build the package
build_package() {
    log_info "Building .deb package..."
    dpkg-deb --build "$DEB_DIR" "$OUTPUT_FILE"
    log_info "Package created: $OUTPUT_FILE"

    # Show package info
    echo ""
    dpkg-deb --info "$OUTPUT_FILE"
}

# Main
main() {
    log_info "Building ${APP_NAME} ${VERSION} for ${ARCH}"

    check_deps
    check_executable
    create_structure
    create_control
    create_desktop_entry
    create_icons
    copy_executable
    build_package

    echo ""
    log_info "Done! Install with: sudo dpkg -i $OUTPUT_FILE"
}

main "$@"
