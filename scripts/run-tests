#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BUILD_DIR="${BUILD_DIR:-"$ROOT_DIR/build"}"

# Source shared config (sets all DEARSQL_TEST_* env vars)
source "$SCRIPT_DIR/test-db-config"

# Ensure build directory exists and build tests
mkdir -p "$BUILD_DIR"
echo "Building database_tests..."
cmake -S "$ROOT_DIR" -B "$BUILD_DIR" > /dev/null
cmake --build "$BUILD_DIR" --target database_tests

echo "Running database tests..."
echo "PostgreSQL: $DEARSQL_TEST_PG_HOST:$DEARSQL_TEST_PG_PORT"
echo "MySQL: $DEARSQL_TEST_MYSQL_HOST:$DEARSQL_TEST_MYSQL_PORT"
echo "Redis: $DEARSQL_TEST_REDIS_HOST:$DEARSQL_TEST_REDIS_PORT"
echo "MongoDB: ${DEARSQL_TEST_MONGODB_HOST:-not set}:${DEARSQL_TEST_MONGODB_PORT:-27017}"
echo ""

cd "$BUILD_DIR"
./database_tests "$@"
