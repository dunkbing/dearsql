#!/usr/bin/env bash

# Setup test databases in Docker for DearSQL tests
# Run this script manually before running tests

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source shared config
source "$SCRIPT_DIR/test-db-config"

# Use sudo for docker if not running as root and user not in docker group
DOCKER="docker"
if ! docker info &> /dev/null 2>&1; then
    DOCKER="sudo docker"
fi

echo "=== DearSQL Test Database Setup ==="
echo ""

# Check if Docker is available
if ! $DOCKER info &> /dev/null; then
    echo "Error: Docker daemon is not running or you don't have permission"
    exit 1
fi

# Function to wait for a port to be ready
wait_for_port() {
    local host="$1"
    local port="$2"
    local name="$3"
    local max_attempts=60
    local attempt=0

    echo -n "Waiting for $name to be ready..."
    while (( attempt < max_attempts )); do
        if (exec 3<>"/dev/tcp/${host}/${port}") 2>/dev/null; then
            exec 3>&-
            echo " Ready!"
            return 0
        fi
        echo -n "."
        sleep 1
        ((attempt++))
    done
    echo " Timeout!"
    return 1
}

# Function to seed PostgreSQL
seed_postgres() {
    echo "Seeding PostgreSQL..."
    # Wait for PostgreSQL to be fully ready inside the container
    echo -n "Waiting for PostgreSQL to accept connections..."
    local max_attempts=30
    local attempt=0
    while (( attempt < max_attempts )); do
        if $DOCKER exec "$POSTGRES_CONTAINER" pg_isready -h localhost -U postgres &>/dev/null; then
            echo " Ready!"
            break
        fi
        echo -n "."
        sleep 1
        ((attempt++))
    done
    if (( attempt >= max_attempts )); then
        echo " Timeout waiting for PostgreSQL!"
        return 1
    fi
    $DOCKER exec -i "$POSTGRES_CONTAINER" psql -h localhost -U postgres -d "$DEARSQL_TEST_PG_DB" <<'EOF'
-- Drop existing tables if they exist
DROP TABLE IF EXISTS order_items CASCADE;
DROP TABLE IF EXISTS orders CASCADE;
DROP TABLE IF EXISTS products CASCADE;
DROP TABLE IF EXISTS users CASCADE;

-- Users table
CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(100) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Products table
CREATE TABLE products (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    stock INT DEFAULT 0
);

-- Orders table
CREATE TABLE orders (
    id SERIAL PRIMARY KEY,
    user_id INT REFERENCES users(id),
    total_amount DECIMAL(10, 2) NOT NULL,
    status VARCHAR(20) DEFAULT 'pending',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Order items table
CREATE TABLE order_items (
    id SERIAL PRIMARY KEY,
    order_id INT REFERENCES orders(id),
    product_id INT REFERENCES products(id),
    quantity INT NOT NULL,
    price DECIMAL(10, 2) NOT NULL
);

-- Insert seed data
INSERT INTO users (username, email) VALUES
    ('alice', 'alice@example.com'),
    ('bob', 'bob@example.com'),
    ('charlie', 'charlie@example.com');

INSERT INTO products (name, price, stock) VALUES
    ('Widget', 19.99, 100),
    ('Gadget', 49.99, 50),
    ('Gizmo', 29.99, 75);

INSERT INTO orders (user_id, total_amount, status) VALUES
    (1, 99.99, 'completed'),
    (1, 149.50, 'pending'),
    (2, 75.00, 'completed');

INSERT INTO order_items (order_id, product_id, quantity, price) VALUES
    (1, 1, 2, 19.99),
    (1, 2, 1, 49.99),
    (2, 3, 5, 29.99),
    (3, 1, 3, 19.99);

-- Create a view
CREATE OR REPLACE VIEW active_users AS
SELECT id, username, email FROM users;
EOF
    echo "PostgreSQL seeded!"
}

# Function to seed MySQL
seed_mysql() {
    echo "Seeding MySQL..."
    # Wait for MySQL to be fully ready inside the container
    echo -n "Waiting for MySQL to accept connections..."
    local max_attempts=30
    local attempt=0
    while (( attempt < max_attempts )); do
        if $DOCKER exec "$MYSQL_CONTAINER" mysqladmin ping -h 127.0.0.1 -u"$DEARSQL_TEST_MYSQL_USER" -p"$DEARSQL_TEST_MYSQL_PASSWORD" &>/dev/null; then
            echo " Ready!"
            break
        fi
        echo -n "."
        sleep 2
        ((attempt++))
    done
    if (( attempt >= max_attempts )); then
        echo " Timeout waiting for MySQL!"
        return 1
    fi
    $DOCKER exec -i "$MYSQL_CONTAINER" mysql -h 127.0.0.1 -u"$DEARSQL_TEST_MYSQL_USER" -p"$DEARSQL_TEST_MYSQL_PASSWORD" "$DEARSQL_TEST_MYSQL_DB" <<'EOF'
-- Drop existing tables if they exist
DROP TABLE IF EXISTS order_items;
DROP TABLE IF EXISTS orders;
DROP TABLE IF EXISTS products;
DROP TABLE IF EXISTS users;

-- Users table
CREATE TABLE users (
    id INT PRIMARY KEY AUTO_INCREMENT,
    username VARCHAR(50) NOT NULL UNIQUE,
    email VARCHAR(100) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Products table
CREATE TABLE products (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(100) NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    stock INT DEFAULT 0
);

-- Orders table
CREATE TABLE orders (
    id INT PRIMARY KEY AUTO_INCREMENT,
    user_id INT,
    total_amount DECIMAL(10, 2) NOT NULL,
    status VARCHAR(20) DEFAULT 'pending',
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

-- Order items table
CREATE TABLE order_items (
    id INT PRIMARY KEY AUTO_INCREMENT,
    order_id INT,
    product_id INT,
    quantity INT NOT NULL,
    price DECIMAL(10, 2) NOT NULL,
    FOREIGN KEY (order_id) REFERENCES orders(id),
    FOREIGN KEY (product_id) REFERENCES products(id)
);

-- Insert seed data
INSERT INTO users (username, email) VALUES
    ('alice', 'alice@example.com'),
    ('bob', 'bob@example.com'),
    ('charlie', 'charlie@example.com');

INSERT INTO products (name, price, stock) VALUES
    ('Widget', 19.99, 100),
    ('Gadget', 49.99, 50),
    ('Gizmo', 29.99, 75);

INSERT INTO orders (user_id, total_amount, status) VALUES
    (1, 99.99, 'completed'),
    (1, 149.50, 'pending'),
    (2, 75.00, 'completed');

INSERT INTO order_items (order_id, product_id, quantity, price) VALUES
    (1, 1, 2, 19.99),
    (1, 2, 1, 49.99),
    (2, 3, 5, 29.99),
    (3, 1, 3, 19.99);

-- Create a view
CREATE OR REPLACE VIEW active_users AS
SELECT id, username, email FROM users;
EOF
    echo "MySQL seeded!"
}

configure_mysql_test_user_privileges() {
    echo "Configuring MySQL test user privileges..."
    local max_attempts=30
    local attempt=0
    while (( attempt < max_attempts )); do
        if $DOCKER exec "$MYSQL_CONTAINER" mysqladmin ping -uroot -pmysql &>/dev/null; then
            break
        fi
        sleep 2
        ((attempt++))
    done
    if (( attempt >= max_attempts )); then
        echo "Error: root MySQL user not ready for privilege grants"
        return 1
    fi

    $DOCKER exec -i "$MYSQL_CONTAINER" mysql -uroot -pmysql <<EOF
GRANT CREATE, DROP ON *.* TO '${DEARSQL_TEST_MYSQL_USER}'@'%';
FLUSH PRIVILEGES;
EOF
    echo "MySQL test user privileges configured!"
}

# Function to seed Redis
seed_redis() {
    echo "Seeding Redis..."
    $DOCKER exec -i "$REDIS_CONTAINER" redis-cli <<'EOF'
FLUSHDB
SET user:1:name "alice"
SET user:1:email "alice@example.com"
SET user:2:name "bob"
SET user:2:email "bob@example.com"
SET user:3:name "charlie"
SET user:3:email "charlie@example.com"
HSET product:1 name "Widget" price "19.99" stock "100"
HSET product:2 name "Gadget" price "49.99" stock "50"
HSET product:3 name "Gizmo" price "29.99" stock "75"
LPUSH recent_orders "order:3" "order:2" "order:1"
SADD active_users "alice" "bob" "charlie"
ZADD leaderboard 100 "alice" 85 "bob" 92 "charlie"
EOF
    echo "Redis seeded!"
}

# Function to seed MongoDB
seed_mongodb() {
    echo "Seeding MongoDB..."
    # Wait a bit more for MongoDB to be fully ready
    sleep 5
    $DOCKER exec -i "$MONGODB_CONTAINER" mongosh --quiet <<'EOF'
use test
db.users.drop()
db.products.drop()
db.orders.drop()

db.users.insertMany([
    { username: "alice", email: "alice@example.com", created_at: new Date() },
    { username: "bob", email: "bob@example.com", created_at: new Date() },
    { username: "charlie", email: "charlie@example.com", created_at: new Date() }
])

db.products.insertMany([
    { name: "Widget", price: 19.99, stock: 100 },
    { name: "Gadget", price: 49.99, stock: 50 },
    { name: "Gizmo", price: 29.99, stock: 75 }
])

db.orders.insertMany([
    { user: "alice", total_amount: 99.99, status: "completed", created_at: new Date() },
    { user: "alice", total_amount: 149.50, status: "pending", created_at: new Date() },
    { user: "bob", total_amount: 75.00, status: "completed", created_at: new Date() }
])

print("MongoDB collections created and seeded")
EOF
    echo "MongoDB seeded!"
}

# Start PostgreSQL
echo ""
echo "--- PostgreSQL ---"
if $DOCKER ps --format '{{.Names}}' | grep -qw "$POSTGRES_CONTAINER"; then
    echo "Container '$POSTGRES_CONTAINER' is already running"
else
    if $DOCKER ps -a --format '{{.Names}}' | grep -qw "$POSTGRES_CONTAINER"; then
        echo "Starting existing container '$POSTGRES_CONTAINER'..."
        $DOCKER start "$POSTGRES_CONTAINER"
    else
        echo "Creating new container '$POSTGRES_CONTAINER'..."
        $DOCKER run -d --name "$POSTGRES_CONTAINER" \
            -e POSTGRES_PASSWORD="$DEARSQL_TEST_PG_PASSWORD" \
            -e POSTGRES_DB="$DEARSQL_TEST_PG_DB" \
            -p "127.0.0.1:${POSTGRES_PORT}:5432" \
            "$POSTGRES_IMAGE"
    fi
fi
wait_for_port "127.0.0.1" "$POSTGRES_PORT" "PostgreSQL"
seed_postgres

# Start MySQL
echo ""
echo "--- MySQL ---"
if $DOCKER ps --format '{{.Names}}' | grep -qw "$MYSQL_CONTAINER"; then
    echo "Container '$MYSQL_CONTAINER' is already running"
else
    if $DOCKER ps -a --format '{{.Names}}' | grep -qw "$MYSQL_CONTAINER"; then
        echo "Starting existing container '$MYSQL_CONTAINER'..."
        $DOCKER start "$MYSQL_CONTAINER"
    else
        echo "Creating new container '$MYSQL_CONTAINER'..."
        $DOCKER run -d --name "$MYSQL_CONTAINER" \
            -e MYSQL_ROOT_PASSWORD=mysql \
            -e MYSQL_DATABASE="$DEARSQL_TEST_MYSQL_DB" \
            -e MYSQL_USER="$DEARSQL_TEST_MYSQL_USER" \
            -e MYSQL_PASSWORD="$DEARSQL_TEST_MYSQL_PASSWORD" \
            -p "127.0.0.1:${MYSQL_PORT}:3306" \
            "$MYSQL_IMAGE"
    fi
fi
wait_for_port "127.0.0.1" "$MYSQL_PORT" "MySQL"
configure_mysql_test_user_privileges
seed_mysql

# Start Redis
echo ""
echo "--- Redis ---"
if $DOCKER ps --format '{{.Names}}' | grep -qw "$REDIS_CONTAINER"; then
    echo "Container '$REDIS_CONTAINER' is already running"
else
    if $DOCKER ps -a --format '{{.Names}}' | grep -qw "$REDIS_CONTAINER"; then
        echo "Starting existing container '$REDIS_CONTAINER'..."
        $DOCKER start "$REDIS_CONTAINER"
    else
        echo "Creating new container '$REDIS_CONTAINER'..."
        $DOCKER run -d --name "$REDIS_CONTAINER" \
            -p "127.0.0.1:${REDIS_PORT}:6379" \
            "$REDIS_IMAGE"
    fi
fi
wait_for_port "127.0.0.1" "$REDIS_PORT" "Redis"
seed_redis

# Start MongoDB
echo ""
echo "--- MongoDB ---"
if $DOCKER ps --format '{{.Names}}' | grep -qw "$MONGODB_CONTAINER"; then
    echo "Container '$MONGODB_CONTAINER' is already running"
else
    if $DOCKER ps -a --format '{{.Names}}' | grep -qw "$MONGODB_CONTAINER"; then
        echo "Starting existing container '$MONGODB_CONTAINER'..."
        $DOCKER start "$MONGODB_CONTAINER"
    else
        echo "Creating new container '$MONGODB_CONTAINER'..."
        $DOCKER run -d --name "$MONGODB_CONTAINER" \
            -p "127.0.0.1:${MONGODB_PORT}:27017" \
            "$MONGODB_IMAGE"
    fi
fi
wait_for_port "127.0.0.1" "$MONGODB_PORT" "MongoDB"
seed_mongodb

echo ""
echo "=== All test databases are ready and seeded! ==="
echo ""
echo "Run tests with: ./scripts/run-tests"
echo ""
echo "To stop containers later:"
echo "  sudo docker stop $POSTGRES_CONTAINER $MYSQL_CONTAINER $REDIS_CONTAINER $MONGODB_CONTAINER"
echo ""
echo "To remove containers:"
echo "  sudo docker rm $POSTGRES_CONTAINER $MYSQL_CONTAINER $REDIS_CONTAINER $MONGODB_CONTAINER"
