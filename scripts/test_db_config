# Shared configuration for test databases
# Source this file in setup and run scripts

# Container names
export POSTGRES_CONTAINER="dearsql-postgres-test"
export MYSQL_CONTAINER="dearsql-mysql-test"
export REDIS_CONTAINER="dearsql-redis-test"

# Docker images
export POSTGRES_IMAGE="postgres:15-alpine"
export MYSQL_IMAGE="mysql:8.0"
export REDIS_IMAGE="redis:7-alpine"

# Ports (host ports mapped to container ports)
export POSTGRES_PORT="${POSTGRES_PORT:-55432}"
export MYSQL_PORT="${MYSQL_PORT:-53306}"
export REDIS_PORT="${REDIS_PORT:-56379}"

# PostgreSQL test config
export DEARSQL_TEST_PG_HOST="127.0.0.1"
export DEARSQL_TEST_PG_PORT="$POSTGRES_PORT"
export DEARSQL_TEST_PG_DB="dearsql_test"
export DEARSQL_TEST_PG_USER="postgres"
export DEARSQL_TEST_PG_PASSWORD="postgres"
export DEARSQL_TEST_PG_NAME="PostgresDocker"

# MySQL test config
export DEARSQL_TEST_MYSQL_HOST="127.0.0.1"
export DEARSQL_TEST_MYSQL_PORT="$MYSQL_PORT"
export DEARSQL_TEST_MYSQL_DB="dearsql_test"
export DEARSQL_TEST_MYSQL_USER="dearsql"
export DEARSQL_TEST_MYSQL_PASSWORD="dearsql"
export DEARSQL_TEST_MYSQL_NAME="MySQLDocker"

# Redis test config
export DEARSQL_TEST_REDIS_HOST="127.0.0.1"
export DEARSQL_TEST_REDIS_PORT="$REDIS_PORT"
export DEARSQL_TEST_REDIS_NAME="RedisDocker"
